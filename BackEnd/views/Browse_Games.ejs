<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Browse Games</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <h1>Available Games</h1>

  <!-- ── Search and filter bar ─────────────────────────── -->
  <div class="filters">

    <input
      type="text"
      id="search-input"
      placeholder="Search games..."
      onkeyup="filterGames()"
    />

    <select id="platform-filter" onchange="filterGames()">
      <option value="all">All Platforms</option>
      <option value="PS4">PS4</option>
      <option value="PS5">PS5</option>
    </select>

    <select id="category-filter" onchange="filterGames()">
      <option value="all">All Categories</option>
      <option value="Action">Action</option>
      <option value="RPG">RPG</option>
      <option value="Sports">Sports</option>
      <option value="Racing">Racing</option>
      <option value="Horror">Horror</option>
    </select>

  </div>

  <!-- ── Games grid ─────────────────────────────────────── -->
  <div class="games-grid" id="games-grid">

    <% if (games.length === 0) { %>

      <p class="no-games">No games available right now.</p>

    <% } else { %>

      <% games.forEach(game => { %>

        <div
          class="game-card"
          data-title="<%= game.title.toLowerCase() %>"
          data-platform="<%= game.platform %>"
          data-category="<%= game.category %>"
        >

          <!-- ── Cover image ──────────────────────────── -->
          <!--
            Priority order for the image:
            1. First image in the Cloudinary images[] array
            2. The single img field (old behaviour)
            3. A placeholder if neither exists
          -->
          <img
            src="<%= (game.images && game.images.length > 0) ? game.images[0] : (game.img || '/images/placeholder.jpg') %>"
            alt="<%= game.title %>"
            class="game-cover"
          />

          <!-- ── Game info ────────────────────────────── -->
          <div class="game-info">

            <h2 class="game-title"><%= game.title %></h2>

            <div class="game-meta">
              <span class="badge platform"><%= game.platform %></span>
              <span class="badge category"><%= game.category %></span>
            </div>

            <% if (game.developer) { %>
              <p class="game-developer">By <%= game.developer %></p>
            <% } %>

            <% if (game.description) { %>
              <p class="game-description"><%= game.description %></p>
            <% } %>

            <div class="game-footer">
              <span class="price"><%= game.pricePerDay %> EGP / day</span>
              <a href="/games/<%= game._id %>" class="btn-details">View Details</a>
            </div>

          </div>
        </div>

      <% }) %>

    <% } %>

  </div>

  <!-- ── Client-side search and filter ─────────────────── -->
  <script>
    function filterGames() {
      const searchValue  = document.getElementById('search-input').value.toLowerCase();
      const platformValue = document.getElementById('platform-filter').value;
      const categoryValue = document.getElementById('category-filter').value;

      const cards = document.querySelectorAll('.game-card');

      cards.forEach(card => {
        const title    = card.dataset.title;
        const platform = card.dataset.platform;
        const category = card.dataset.category;

        const matchesSearch   = title.includes(searchValue);
        const matchesPlatform = platformValue === 'all' || platform === platformValue;
        const matchesCategory = categoryValue === 'all' || category === categoryValue;

        if (matchesSearch && matchesPlatform && matchesCategory) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    }
  </script>

</body>
</html>