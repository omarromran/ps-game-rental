<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PSHUB | Browse Games</title>

    <link rel="stylesheet" href="/cssFiles/BrowseGames.css">
    <link rel="icon" href="/photos/images.png">

    <script>
        window.serverGames = " JSON.stringify(games || [])";
    </script>
    <script src="/jsFiles/Browse_Games.js" defer></script>
</head>

<body>

    <!-- ========================= -->
    <!-- NAVBAR -->
    <!-- ========================= -->
    <header class="navbar">

        <div class="logo" onclick="window.location.href='/'">
            PS<span>HUB</span>
        </div>

        <div class="header-right">

            <div class="cart-icon" onclick="toggleCart()">
                🛒 <span id="cart-count">0</span>
            </div>

            <div class="user-profile">

                <% if (user) { %>

                    <a 
                        id="user-name-link"
                        class="user-name"
                        href="/gamerDashboard"
                        style="text-decoration:none; color:inherit;"
                    >
                        <%= user.username %>
                    </a>

                    <button 
                        id="logout-btn"
                        onclick="logout()"
                        style="
                            background:none;
                            border:none;
                            color:white;
                            cursor:pointer;
                            margin-left:10px;
                        "
                    >
                        Logout
                    </button>

                <% } else { %>

                    <a 
                        href="/login"
                        class="login-btn"
                    >
                        Login
                    </a>

                <% } %>

            </div>
        </div>
    </header>

    <!-- ========================= -->
    <!-- TOOLBAR -->
    <!-- ========================= -->
    <div class="toolbar">

        <div class="search-container">
            <input 
                type="text"
                id="mainSearch"
                placeholder="Search title or ID..."
            >
        </div>

        <div class="filter-group">

            <div class="price-inputs">
                <input type="number" id="minPrice" placeholder="Min EGP">
                <input type="number" id="maxPrice" placeholder="Max EGP">
            </div>

            <!-- Platform Filter -->
            <div class="dropdown">

                <button class="drop-btn">
                    Platform ▾
                </button>

                <div class="dropdown-content" id="platform-filters">

                    <label>
                        <input 
                            type="checkbox"
                            value="PS5"
                            onchange="applyFilters()"
                        >
                        PS5
                    </label>

                    <label>
                        <input 
                            type="checkbox"
                            value="PS4"
                            onchange="applyFilters()"
                        >
                        PS4
                    </label>

                </div>
            </div>

            <!-- Genre Filter -->
            <div class="dropdown">

                <button class="drop-btn">
                    Genre ▾
                </button>

                <div class="dropdown-content" id="category-filters">

                    <label>
                        <input 
                            type="checkbox"
                            value="Action"
                            onchange="applyFilters()"
                        >
                        Action
                    </label>

                    <label>
                        <input 
                            type="checkbox"
                            value="FPS"
                            onchange="applyFilters()"
                        >
                        FPS
                    </label>

                    <label>
                        <input 
                            type="checkbox"
                            value="Telltale"
                            onchange="applyFilters()"
                        >
                        Telltale
                    </label>

                    <label>
                        <input 
                            type="checkbox"
                            value="Platform"
                            onchange="applyFilters()"
                        >
                        Platform
                    </label>

                </div>
            </div>

        </div>
    </div>

    <!-- ========================= -->
    <!-- STORE -->
    <!-- ========================= -->
    <main class="store-container">

        <div class="inventory-header">

            <h1 id="view-title">
                All Games
            </h1>

            <span id="item-count">
                <%= games ? games.length : 0 %> games found
            </span>

        </div>

        <!-- ========================= -->
        <!-- GAME GRID -->
        <!-- ========================= -->
        <div class="game-grid" id="game-grid">

            <% if (games && games.length > 0) { %>

                <% games.forEach(game => { %>

                    <div 
                        class="game-card"
                        onclick="window.location.href='/game_description?id=<%= game._id %>'"
                        style="cursor:pointer;"
                    >

                        <!-- GAME IMAGE -->
                        <img
                            src="<%= game.img || game.image || '/photos/placeholder.png' %>"
                            alt="<%= game.title %>"
                            class="game-image"
                        >

                        <!-- WISHLIST -->
                        <div
                            class="wishlist-btn"
                            onclick="event.stopPropagation(); toggleWishlist('<%= game._id %>')"
                        >
                            🤍
                        </div>

                        <!-- GAME INFO -->
                        <div class="game-info">

                            <h3>
                                <%= game.title %>
                            </h3>

                            <p class="platform-text">
                                <%= game.platform %>
                            </p>

                            <p class="category-text">
                                <%= game.category %>
                            </p>

                            <div class="price">
                                <%= game.pricePerDay || game.price || 0 %> EGP/day
                            </div>

                            <!-- ADD TO CART -->
                            <button
                                class="add-btn"
                                onclick="event.stopPropagation(); addToCart('<%= game._id %>')"
                            >
                                Add to Cart
                            </button>

                        </div>
                    </div>

                <% }) %>

            <% } else { %>

                <div class="no-games">
                    No games available
                </div>

            <% } %>

        </div>
    </main>

    <!-- ========================= -->
    <!-- CART -->
    <!-- ========================= -->
    <div id="cart-sidebar" class="cart-sidebar">

        <div class="cart-header">

            <h2>Your Cart</h2>

            <button
                class="close-btn"
                onclick="toggleCart(false)"
            >
                ×
            </button>

        </div>

        <div id="cart-items" class="cart-items-container"></div>

        <div class="cart-footer">

            <div class="total">
                Total:
                <span id="cart-total">0.00</span>
                EGP
            </div>

            <button
                class="checkout-btn"
                onclick="checkout()"
            >
                Checkout
            </button>

        </div>
    </div>

    <!-- ========================= -->
    <!-- LOGOUT SCRIPT -->
    <!-- ========================= -->
    <script>

        async function logout() {

            try {

                await fetch("/api/auth/logout", {
                    method: "POST"
                });

                window.location.href = "/login";

            } catch (error) {

                console.log(error);
            }
        }

    </script>

</body>

</html>