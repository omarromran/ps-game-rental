<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lender Dashboard - PS Rental Hub</title>

    <link rel="icon" href="/photos/images.png">
    <link rel="stylesheet" href="/cssFiles/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <script defer src="/jsFiles/storedashboard.js"></script>
</head>

<body>
    <% const storeGames=typeof games !=='undefined' ? games : []; const activityList=typeof activities !=='undefined' ?
        activities : []; const activeRentalsValue=typeof activeRentals !=='undefined' ? activeRentals : 0; const
        totalEarningsValue=typeof totalEarnings !=='undefined' ? totalEarnings : 0; %>

        <div class="dashboard-wrapper">

            <aside class="sidebar">
                <div class="sidebar-header">
                    <h2>PS HUB</h2>
                </div>
                <nav>
                    <button onclick="showSection('dashboard', this)" class="active">
                        <i class="fas fa-tachometer-alt"></i>
                        Store Dashboard
                    </button>
                    <button onclick="showSection('addGame', this)">
                        <i class="fas fa-plus-circle"></i>
                        Add New Game
                    </button>
                    <button onclick="showSection('manageGames', this)">
                        <i class="fas fa-tasks"></i>
                        Manage Games
                    </button>
                </nav>

                <button class="logout" id="logoutBtn">
                    <i class="fas fa-sign-out-alt"></i>
                    Logout
                </button>
            </aside>

            <main>

                <section id="dashboard">
                    <div class="card-container">
                        <div class="card">
                            <h3>Total Games</h3>
                            <p id="totalGames">
                                <%= storeGames.length %>
                            </p>
                        </div>
                        <div class="card">
                            <h3>Active Rentals</h3>
                            <p id="activeRentals">
                                <%= activeRentalsValue %>
                            </p>
                        </div>
                        <div class="card">
                            <h3>Total Earnings</h3>
                            <p id="totalEarnings">
                                <%= totalEarningsValue %> EGP
                            </p>
                        </div>
                    </div>

                    <div style="margin-top: 3rem;">
                        <h3>Recent Activity</h3>
                        <table>
                            <thead>
                                <tr>
                                    <th>Game</th>
                                    <th>Customer</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody id="activityLog">
                                <% if (activityList && activityList.length> 0) { %>
                                    <% activityList.forEach(activity=> { %>
                                        <tr>
                                            <td>
                                                <%= activity.gameTitle %>
                                            </td>
                                            <td>
                                                <%= activity.customerName %>
                                            </td>
                                            <td>
                                                <%= activity.status %>
                                            </td>
                                            <td>
                                                <%= activity.date %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="4" style="text-align:center;">No recent activity</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </section>

                <section id="addGame" style="display:none;">
                    <h2 id="gameFormTitle">List a New Game</h2>
                    
                    <!-- 🔍 RAWG API Search Section -->
                    <div class="search-external-game">
                        <h3>Search for Game Metadata</h3>
                        <p style="font-size: 0.9rem; color: #666; margin-bottom: 1rem;">Search the RAWG database to auto-fill game details</p>
                        <div class="search-container">
                            <input 
                                type="text" 
                                id="gameSearchInput" 
                                placeholder="Search game by title (e.g., Uncharted, The Last of Us)..." 
                                class="search-input"
                                autocomplete="off"
                            >
                            <button type="button" id="searchGameBtn" class="search-btn">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </div>
                        <div id="searchResults" class="search-results" style="display:none;"></div>
                    </div>

                    <hr style="margin: 2rem 0; border: none; border-top: 1px solid #ddd;">

                    <form id="addGameForm" action="/api/games" method="POST" enctype="multipart/form-data" autocomplete="off">
                        <input type="hidden" id="editGameId" name="editGameId" value="">

                        <div class="form-group">
                            <label>Game Title</label>
                            <input type="text" autocomplete="off" id="gameTitle" name="title" required>
                        </div>

                        <div class="form-group">
                            <label>Platform</label>
                            <select id="platform" name="platform" required>
                                <option value="">Select Platform</option>
                                <option value="PS5">PlayStation 5</option>
                                <option value="PS4">PlayStation 4</option>
                                <option value="PS4 & PS5">PlayStation 4 & 5</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Genre</label>
                            <select id="genre" name="category" required>
                                <option value="">Select Genre</option>
                                <option value="Action">Action</option>
                                <option value="RPG">RPG</option>
                                <option value="Sports">Sports</option>
                                <option value="Horror">Horror</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Daily Price (EGP)</label>
                            <input type="number" id="dailyPrice" name="pricePerDay" min="0" required>
                        </div>

                        <div class="form-group">
                            <label>Description</label>
                            <textarea id="description" name="description"></textarea>
                        </div>

                        <div class="form-group">
                            <label>Game Images</label>
                            <input type="file" id="images" name="images" multiple accept="image/*" required>
                            <small id="imageHint">Upload at least one image to create a new game.</small>
                            <div id="selectedImagesPreview" class="selected-images-preview"></div>
                        </div>

                        <p id="form-error-msg" style="color:red; font-size:0.85rem; display:none; margin-bottom:10px;">
                        </p>

                        <button type="submit" id="submitGameButton" class="submit-btn">Add Game</button>
                        <button type="button" id="cancelEditButton" class="submit-btn"
                            style="display:none; margin-left:10px; background:#888;"
                            onclick="cancelGameEdit()">Cancel</button>
                    </form>
                </section>

                <section id="manageGames" style="display:none;">
                    <h2>Manage Your Games</h2>
                    <table id="gamesTable">
                        <thead>
                            <tr>
                                <th>Game Title</th>
                                <th>Platform</th>
                                <th>Genre</th>
                                <th>Daily Price</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="gamesList">
                            <% if (storeGames && storeGames.length> 0) { %>
                                <% storeGames.forEach(game=> { %>
                                    <tr>
                                        <td>
                                            <%= game.title %>
                                        </td>
                                        <td>
                                            <%= game.platform %>
                                        </td>
                                        <td>
                                            <%= game.category %>
                                        </td>
                                        <td>
                                            <%= (game.pricePerDay || game.price || 0) %> EGP
                                        </td>
                                        <td>
                                            <% if (typeof game.status !=='undefined' ) { %>
                                                <% if (game.status==='Available' ) { %>
                                                    <span style="color: #4caf50;">Available</span>
                                                    <% } else if (game.status==='Maintenance' ) { %>
                                                        <span style="color: #ff9800;">Maintenance</span>
                                                        <% } else { %>
                                                            <span style="color: #f44336;">Rented</span>
                                                            <% } %>
                                                                <% } else if (game.available !==false) { %>
                                                                    <span style="color: #4caf50;">Available</span>
                                                                    <% } else { %>
                                                                        <span style="color: #f44336;">Rented</span>
                                                                        <% } %>
                                        </td>
                                        <td>
                                            <button type="button" onclick="startGameEdit('<%= game._id %>')"
                                                style="background:none; border:none; color:#007bff; cursor:pointer; margin-right:8px;">
                                                <i class="fas fa-edit"></i> Edit
                                            </button>
                                            <button type="button"
                                                onclick="deleteGame('<%= game._id %>')">Delete</button>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr id="noGamesMessage">
                                                <td colspan="6" style="text-align:center; padding:1rem;">You have no listed games yet.</td>
                                            </tr>
                                        <% } %>
                        </tbody>
                    </table>


                </section>

            </main>
        </div>

</body>

</html>