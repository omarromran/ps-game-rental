<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PSHUB | Checkout</title>
    <link rel="stylesheet" href="/cssFiles/checkout.css">
    <link rel="icon" href="/photos/images.png">
    <script src="/jsFiles/checkout.js" defer></script>
</head>

<body>

    <header class="navbar">
        <div class="logo" onclick="window.location.href='/browse-games'">PS<span>HUB</span></div>
        <div class="header-right">
           <div class="user-profile">
    <a class="user-name" id="user-name-link" href="/gamer-dashboard" style="text-decoration:none; color:inherit; cursor:pointer;"> </a>
</div>
        </div>
    </header>

    <main class="checkout-container">
        <div class="checkout-main">
            <button class="back-link" onclick="window.location.href='/browse-games'">← Back to Store</button>

            <section class="order-review">
                <h2>Review Your Rental</h2>
                <div id="checkout-list" class="horizontal-list">
                </div>
            </section>

            <section class="delivery-form">
                <h2>Delivery Information</h2>

                <div class="form-group">
                    <label for="phone">Phone Number (Egyptian)</label>
                    <input type="tel" id="phone" placeholder="01xxxxxxxxx" maxlength="11">
                </div>

                <div class="form-group">
                    <label for="address">Full Shipping Address</label>
                    <input type="text" id="address" placeholder="Street name, Building, Apartment...">
                </div>

                <div class="form-group">
                    <label for="days">Rental Duration (days)</label>
                    <input type="number" id="days" placeholder="3" min="1" max="30" value="3">
                </div>

            </section>
        </div>

        <aside class="checkout-summary">
            <h3>Order Summary</h3>

            <div class="payment-section">
                <p class="section-label">Payment Method</p>
                <label class="payment-option">
                    <input type="radio" name="payment" checked>
                    <span class="radio-custom"></span>
                    <span>Cash on Delivery</span>
                </label>
            </div>

            <div class="price-breakdown">
                <div class="price-row">
                    <span>Subtotal</span>
                    <span><span id="subtotal">0.00</span> EGP</span>
                </div>
                <div class="price-row total-row">
                    <span>Total</span>
                    <span><span id="final-total">0.00</span> EGP</span>
                </div>
            </div>

            <button class="confirm-btn" onclick="processOrder()">Confirm Rental</button>
        </aside>
    </main>

    <div id="success-overlay" class="success-overlay">
        <div class="success-content">
            <div class="checkmark-circle">
                <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                    <circle class="checkmark-circle-bg" cx="26" cy="26" r="25" fill="none" />
                    <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8" />
                </svg>
            </div>
            <h1>Order Confirmed!</h1>
            <p id="success-message">Your rental is ready.</p>
        </div>
    </div>

</body>

</html>
