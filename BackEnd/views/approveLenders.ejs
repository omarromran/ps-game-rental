<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Approve Stores</title>
    <link rel="stylesheet" href="cssFiles/approveLenders.css">
    <link rel="icon" href="photos/images.png">
</head>

<body>
    <div class="table-container">
        <h2>Pending Store Approvals</h2>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Store Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody id="lender-table-body"></tbody>
        </table>
    </div>

    <script>
        let users = [];

        async function loadPendingStores() {
            try {
                const res = await fetch('/api/users');
                if (!res.ok) throw new Error('Failed to fetch users');

                const data = await res.json();
                users = data;

                renderTable();
            } catch (err) {
                console.error(err);
                document.getElementById('lender-table-body').innerHTML =
                    `<tr><td colspan="5" style="text-align:center">Error loading data</td></tr>`;
            }
        }

        function renderTable() {
            const tableBody = document.getElementById('lender-table-body');
            tableBody.innerHTML = "";

            // ONLY STORES THAT ARE NOT APPROVED
            const pendingStores = users.filter(u =>
                u.role === "Store" && u.approved === false
            );

            if (pendingStores.length === 0) {
                tableBody.innerHTML =
                    `<tr><td colspan="5" style="text-align:center">No pending approvals.</td></tr>`;
                return;
            }

            pendingStores.forEach(store => {
                const row = `
                    <tr id="row-${store._id}">
                        <td>${store._id}</td>
                        <td><strong>${store.username}</strong></td>
                        <td>${store.email}</td>
                        <td><span class="status-badge">Pending</span></td>
                        <td>
                            <button class="btn-check" onclick="handleApproval('${store._id}', 'approve')">
                                Accept
                            </button>
                            <button class="btn-trash" onclick="handleApproval('${store._id}', 'decline')">
                                Decline
                            </button>
                        </td>
                    </tr>
                `;
                tableBody.innerHTML += row;
            });
        }

        async function handleApproval(id, action) {
            try {
                if (action === 'approve') {
                    const res = await fetch(`/api/users/${id}/approve`, {
                        method: 'PATCH'
                    });

                    if (!res.ok) throw new Error('Approve failed');

                    users = users.map(u =>
                        u._id === id ? { ...u, approved: true } : u
                    );

                    alert('Store approved');
                } else {
                    const res = await fetch(`/api/users/${id}`, {
                        method: 'DELETE'
                    });

                    if (!res.ok) throw new Error('Delete failed');

                    users = users.filter(u => u._id !== id);

                    alert('Store declined');
                }

                const row = document.getElementById(`row-${id}`);
                row.remove();

                if (users.filter(u => u.role === "Store" && !u.approved).length === 0) {
                    renderTable();
                }

            } catch (err) {
                console.error(err);
                alert('Operation failed');
            }
        }

        document.addEventListener("DOMContentLoaded", loadPendingStores);
    </script>
</body>

</html>